{
  "source": "Computed from ДОМ.РФ mortgage originations + Avito/Домклик rental listing counts",
  "methodology": "Permanence Ratio = local_mortgages / (local_mortgages + active_rental_listings) × 100. Mariupol adjusted: only 18% of mortgage buyers counted as local (PSB disclosure: ~82% inter-regional speculative). Score 0-100. Critical threshold in 2% mortgage environment: below 50 = renting premium over owning, explicit permanence uncertainty signal.",
  "buy_vs_rent_economics": {
    "notes": "At 2% on ₽3M over 30 years monthly payment ~₽11,000. Donetsk/Luhansk rental rates ₽15,000-20,000/month. Buying is cheaper than renting on monthly cash flow. Anyone renting is paying a premium for optionality — that premium IS the signal.",
    "mariupol_new_build": "₽170,000/m² × 35m² studio = ₽5.95M. At 10% down (₽595k) + 2% mortgage on ₽5.35M = ~₽19,800/month. Above rental parity — explains why speculative buyers dominate over local residents.",
    "donetsk_secondary": "₽35,000/m² × 35m² = ₽1.225M. At 10% down + 2% = ~₽4,500/month. Well below rental. Anyone renting in Donetsk is making a strong optionality bet.",
    "luhansk_secondary": "₽30,000/m² × 35m² = ₽1.05M. At 10% down + 2% = ~₽3,900/month. Cheapest buy-vs-rent spread in corridor. Renting here is maximum optionality signal."
  },
  "alert_thresholds": {
    "critical_below": 50,
    "warning_below": 65,
    "stable_above": 75,
    "notes": "Below 50 in 2% environment = alarm. Below 65 = watch. Above 75 = genuine permanence confidence."
  },
