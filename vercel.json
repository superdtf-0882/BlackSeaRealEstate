{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://davidfacer.com" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ],
  "crons": [],
  "rewrites": [
    { "source": "/api/digest/:date", "destination": "/api/digest" }
  ]
}
