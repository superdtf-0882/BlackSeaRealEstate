{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://davidfacer.com" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ],
  "crons": [],
  "_pending_crons": [
    { "path": "/api/monitor", "schedule": "0 7 * * *" }
  ]
}
